# =============================
# CANDIDATURE SERVICE - SMTP
# =============================
# Mettre EMAIL_MODE=smtp pour envoyer des emails reels
EMAIL_MODE=smtp

# Expediteur
DEFAULT_FROM_EMAIL=ISIMM Admission <votre-email@gmail.com>

# Serveur SMTP (exemple Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Identifiants SMTP
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre_app_password

# Optionnel
EMAIL_TIMEOUT=20

# Exemple local (emails seulement dans console)
# EMAIL_MODE=console
